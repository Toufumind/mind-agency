{
  "name": "mind-agency",
  "version": "0.8.0",
  "description": "Mind Agency — From Agent to Agency. 一个 AI 做不了的事，一群 AI 可以。",
  "scripts": {
    "build:mcp": "node scripts/build-mcp.mjs",
    "dev": "npm run build:mcp && next dev",
    "dev:ws": "npx tsx server.ts",
    "dev:all": "npm run build:mcp && concurrently \"next dev\" \"npx tsx server.ts\"",
    "build": "npm run build:mcp && next build",
    "build:exe": "npm run build:mcp && node scripts/build-exe.mjs",
    "release": "node scripts/release.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "main": "./electron/main.cjs",
  "keywords": [
    "agent",
    "agency",
    "collaboration",
    "multi-agent",
    "workflow",
    "ai",
    "claude",
    "mcp"
  ],
  "author": "Toufumind",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Toufumind/mind-agency.git"
  },
  "homepage": "https://github.com/Toufumind/mind-agency#readme",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.159",
    "@lancedb/lancedb": "^0.30.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.400.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@yao-pkg/pkg": "^6.20.0",
    "caxa": "^3.0.1",
    "concurrently": "^10.0.0",
    "electron": "^42.3.0",
    "esbuild": "^0.28.0",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
