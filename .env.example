# Mind Agency — Environment Variables (optional)

# WebSocket server port
WS_PORT=3001

# Agent polling interval (ms)
POLL_INTERVAL=30000

# Workflow DAG check interval (ms)
DAG_INTERVAL=5000

# Max CPU load before agent pause (0-1)
MAX_CPU_LOAD=0.8

# Claude Code binary path (for agent execution)
# CLAUDE_CODE_PATH=claude

# Codex model (if using OpenAI provider)
# CODEX_MODEL=gpt-4o
